# ─── Infrastructure ─────────────────────────────
# Postgres
POSTGRES_USER=selora
POSTGRES_PASSWORD=selora_dev_password
POSTGRES_DB=selora
DATABASE_URL=postgresql://selora:selora_dev_password@postgres:5432/selora?schema=public

# Redis
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible)
MINIO_ROOT_USER=selora
MINIO_ROOT_PASSWORD=selora_dev_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=selora-artifacts
S3_ACCESS_KEY=selora
S3_SECRET_KEY=selora_dev_password
S3_ENDPOINT=http://minio:9000
S3_BUCKET=selora-artifacts
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Storage driver: s3 | local
STORAGE_DRIVER=s3

# ─── Application ───────────────────────────────
NODE_ENV=development
QUEUE_MODE=bullmq

# API
API_PORT=4000
API_SESSION_SECRET=dev-session-secret-change-in-prod
SECRET_ENCRYPTION_KEY=dev-encryption-key-change-in-prod
ARTIFACT_SIGNING_SECRET=dev-artifact-signing-secret-change-in-prod
ARTIFACT_DOWNLOAD_TTL_SECONDS=900

# CORS & public URLs
WEB_ORIGIN=http://localhost:3000
API_PUBLIC_ORIGIN=http://localhost:4000

# Rate limits (requests per minute)
API_RATE_LIMIT_USER_PER_MINUTE=60
API_RATE_LIMIT_TENANT_PER_MINUTE=600

# Ollama for Dockerized services
AI_PROVIDER_BASE_URL=http://host.docker.internal:11434/v1
AI_PROVIDER_API_URL=http://host.docker.internal:11434/v1
AI_PROVIDER_API_KEY=ollama
AI_MODEL=qwen3.5:9b
AI_REPAIR_MODEL=qwen3.5:9b
AI_LLM_TIMEOUT_MS=120000

# Execution & Validation
EXECUTION_TIMEOUT_MS=120000
VALIDATION_TIMEOUT_MS=60000
PLAYWRIGHT_RUNNER_IMAGE=selora-playwright-runner
DOCKER_NETWORK=selora_default
VALIDATION_HOST_ROOT=/tmp/selora-validation

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_PORT=3000

# Mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@selora.local
SMTP_USER=
SMTP_PASSWORD=
