// ──────────────────────────────────────────────────────────────
// Selora – Prisma Schema
// Generated from: docs/data/prisma-data-design.md
//                  docs/data/domain-schema.md
// ──────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────── Enums ────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum SuiteStatus {
  ACTIVE
  ARCHIVED
}

enum GitHubCredentialMode {
  PAT
  GITHUB_APP
}

enum GitHubIntegrationStatus {
  CONNECTED
  INVALID
  DISCONNECTED
}

enum GitHubWriteScope {
  READ_ONLY
  BRANCH_PUSH
  PULL_REQUESTS
}

enum PublicationStatus {
  PENDING
  PUBLISHED
  MERGED
  CLOSED
  FAILED
}

enum PublicationPullRequestState {
  OPEN
  CLOSED
  MERGED
}

enum GitHubWebhookDeliveryStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum TestRailIntegrationStatus {
  CONNECTED
  INVALID
  DISCONNECTED
}

enum TestRailSyncPolicy {
  MANUAL
}

enum TestRailSyncRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum TestRailCaseLinkStatus {
  MAPPED
  SYNCED
  FAILED
}

enum ExecutionSourceRequestMode {
  SUITE_DEFAULT
  PINNED_COMMIT
  BRANCH_HEAD
}

enum BusinessTestCaseFormat {
  SIMPLE
  STRUCTURED
}

enum BusinessTestCaseSource {
  MANUAL
  TESTRAIL_IMPORT
  CSV_IMPORT
}

enum BusinessTestCaseStatus {
  ACTIVE
  ARCHIVED
}

enum BusinessTestCasePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TestCaseVerdict {
  PASSED
  FAILED
  NOT_COVERED
  SKIPPED
}

enum ScreenshotPolicy {
  ALWAYS
  ON_FAIL_ONLY
  NEVER
}

enum ExecutionSourceMode {
  STORAGE_ARTIFACT
  PINNED_COMMIT
  BRANCH_HEAD
}

enum RolloutStage {
  INTERNAL
  PILOT
  GENERAL
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum MembershipRole {
  PLATFORM_ADMIN
  TENANT_ADMIN
  TENANT_OPERATOR
  TENANT_VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  REVOKED
}

enum EnvironmentStatus {
  ACTIVE
  DISABLED
}

enum RecordingSourceType {
  PLAYWRIGHT_CODEGEN_TS
}

enum RecordingStatus {
  UPLOADED
  PROCESSING
  NORMALIZED
  FAILED
  ARCHIVED
}

enum TestStatus {
  INGESTED
  GENERATED
  VALIDATING
  VALIDATED
  AUTO_REPAIRED
  NEEDS_HUMAN_REVIEW
  ARCHIVED
}

enum GeneratedTestStatus {
  CREATED
  VALIDATING
  READY
  FAILED
  ARCHIVED
}

enum RunType {
  MANUAL
  SCHEDULED
  CI_TRIGGERED
}

enum RunStatus {
  QUEUED
  VALIDATING
  REPAIRING
  READY
  RUNNING
  PASSED
  FAILED
  CANCELED
  TIMED_OUT
}

enum ArtifactType {
  LOG
  SCREENSHOT
  TRACE
  VIDEO
  GENERATED_TEST
  REPAIR_DIFF
  VISUAL_DIFF
}

enum RepairMode {
  RULE_BASED
  LLM_ASSISTED
}

enum RepairStatus {
  SUGGESTED
  APPLIED
  RERUN_PASSED
  RERUN_FAILED
  ABANDONED
  HUMAN_REVIEW_REQUIRED
}

enum MetricType {
  RUN_COUNT
  EXECUTION_MINUTES
  ARTIFACT_STORAGE_BYTES
  CONCURRENT_EXECUTIONS
  AI_REPAIR_ATTEMPTS
  API_REQUESTS_PER_MINUTE
  USER_SEATS
  WORKSPACE_COUNT
}

enum FeedbackCategory {
  BUG
  UX
  PERFORMANCE
  INTEGRATION
  FEATURE_REQUEST
  OTHER
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FeedbackStatus {
  SUBMITTED
  REVIEWED
  PLANNED
  DEFERRED
  CLOSED
}

enum LlmProviderType {
  OPENAI
  ANTHROPIC
  GOOGLE_GEMINI
  OLLAMA
  AZURE_OPENAI
  CUSTOM
}

// ──────────────── Ownership & Auth Models ────────────────

model Tenant {
  id        String       @id @default(uuid())
  slug      String       @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  suspendedAt DateTime?
  archivedAt DateTime?
  softDeleteRequestedAt DateTime?
  softDeleteScheduledFor DateTime?
  githubPublishingEnabled  Boolean @default(false)
  gitExecutionEnabled      Boolean @default(false)
  testRailSyncEnabled      Boolean @default(false)
  maxRolloutStage          RolloutStage @default(INTERNAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  workspaces  Workspace[]
  automationSuites AutomationSuite[]
  githubSuiteIntegrations GitHubSuiteIntegration[]
  testRailSuiteIntegrations TestRailSuiteIntegration[]
  testRailSyncRuns TestRailSyncRun[]
  generatedArtifactPublications GeneratedArtifactPublication[]
  gitHubWebhookDeliveries GitHubWebhookDelivery[]
  memberships Membership[]
  auditEvents AuditEvent[]
  usageMeters UsageMeter[]
  quotas      TenantQuota[]
  testRuns    TestRun[]
  betaFeedback BetaFeedback[]
  githubRepositoryAllowlist GitHubRepositoryAllowlistEntry[]
  llmSelection TenantLlmSelection?

  @@map("tenants")
}

model TenantQuota {
  id        String     @id @default(uuid())
  tenantId  String
  metricType MetricType
  limitValue Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metricType])
  @@map("tenant_quotas")
}

model Workspace {
  id       String          @id @default(uuid())
  tenantId String
  slug     String
  name     String
  status   WorkspaceStatus @default(ACTIVE)
  concurrentExecutionLimit Int @default(5)
  maxTestsPerRun           Int @default(25)
  runCooldownSeconds       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  memberships            Membership[]
  automationSuites       AutomationSuite[]
  githubSuiteIntegrations GitHubSuiteIntegration[]
  testRailSuiteIntegrations TestRailSuiteIntegration[]
  externalTestCaseLinks ExternalTestCaseLink[]
  testRailSyncRuns TestRailSyncRun[]
  generatedArtifactPublications GeneratedArtifactPublication[]
  gitHubWebhookDeliveries GitHubWebhookDelivery[]
  environments           Environment[]
  recordingAssets        RecordingAsset[]
  canonicalTests         CanonicalTest[]
  generatedTestArtifacts GeneratedTestArtifact[]
  businessTestCases      BusinessTestCase[]
  testRuns               TestRun[]
  artifacts              Artifact[]
  auditEvents            AuditEvent[]
  aiRepairAttempts       AIRepairAttempt[]
  retentionSetting       RetentionSetting?
  activeSessions         UserSession[]
  betaFeedback           BetaFeedback[]
  githubRepositoryAllowlist GitHubRepositoryAllowlistEntry[]
  visualBaselines        VisualBaseline[]
  testFileMappings       TestFileMapping[]
  smartSelectionRuns     SmartSelectionRun[]
  apiTestDefinitions     ApiTestDefinition[]
  apiTestExecutions      ApiTestExecution[]

  @@unique([tenantId, slug])
  @@map("workspaces")
}

model AutomationSuite {
  id          String      @id @default(uuid())
  tenantId    String
  workspaceId String
  slug        String
  name        String
  description String?
  status      SuiteStatus @default(ACTIVE)
  isDefault   Boolean     @default(false)
  executionSourcePolicy        ExecutionSourceMode @default(STORAGE_ARTIFACT)
  allowBranchHeadExecution     Boolean             @default(false)
  allowStorageExecutionFallback Boolean            @default(true)
  rolloutStage                 RolloutStage        @default(INTERNAL)
  githubPublishingEnabled      Boolean             @default(true)
  gitExecutionEnabled          Boolean             @default(true)
  testRailSyncEnabled          Boolean             @default(true)
  screenshotPolicy             ScreenshotPolicy    @default(ALWAYS)

  // ── Schedule Fields ──
  scheduleEnabled        Boolean  @default(false)
  scheduleCron           String?
  scheduleEnvironmentId  String?
  scheduleTimezone       String   @default("UTC")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scheduleEnvironment Environment? @relation("ScheduleEnvironment", fields: [scheduleEnvironmentId], references: [id], onDelete: SetNull)
  canonicalTests CanonicalTest[]
  businessTestCases BusinessTestCase[]
  githubIntegration GitHubSuiteIntegration?
  testRailIntegration TestRailSuiteIntegration?
  externalTestCaseLinks ExternalTestCaseLink[]
  testRailSyncRuns TestRailSyncRun[]
  generatedArtifactPublications GeneratedArtifactPublication[]
  gitHubWebhookDeliveries GitHubWebhookDelivery[]
  testRuns TestRun[]
  apiTestDefinitions ApiTestDefinition[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([tenantId, createdAt])
  @@map("automation_suites")
}

model GitHubSuiteIntegration {
  id                String                  @id @default(uuid())
  tenantId          String
  workspaceId       String
  suiteId           String                  @unique
  credentialMode    GitHubCredentialMode
  status            GitHubIntegrationStatus @default(DISCONNECTED)
  repoOwner         String
  repoName          String
  defaultBranch     String
  workflowPath      String?
  allowedWriteScope GitHubWriteScope        @default(READ_ONLY)
  pullRequestRequired Boolean               @default(true)
  secretRef         String?
  encryptedSecretJson String?
  appId             String?
  appSlug           String?
  installationId    String?
  healthSummaryJson Json?
  lastValidatedAt   DateTime?
  secretRotatedAt   DateTime?
  secretRotatedByUserId String?
  webhookSecretRef String?
  webhookSecretEncryptedJson String?
  webhookSecretRotatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite AutomationSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  secretRotatedByUser User? @relation("GitHubIntegrationSecretRotatedBy", fields: [secretRotatedByUserId], references: [id], onDelete: SetNull)
  publications GeneratedArtifactPublication[]
  webhookDeliveries GitHubWebhookDelivery[]

  @@index([workspaceId, status])
  @@index([tenantId, updatedAt])
  @@index([repoOwner, repoName])
  @@map("github_suite_integrations")
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  name             String
  avatarUrl        String?
  prefersCompactNavigation Boolean @default(false)
  prefersEmailNotifications Boolean @default(true)
  prefersRunDigest Boolean @default(true)
  prefersAutoOpenFailures Boolean @default(true)
  passwordHash     String
  passwordVersion  Int        @default(1)
  emailVerifiedAt  DateTime?
  resetRequestedAt DateTime?
  lastLoginAt      DateTime?
  status           UserStatus @default(INVITED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships      Membership[]
  recordingAssets  RecordingAsset[]     @relation("UploadedByUser")
  generatedTests   GeneratedTestArtifact[] @relation("CreatedByUser")
  generatedArtifactPublications GeneratedArtifactPublication[]
  triggeredRuns    TestRun[]            @relation("TriggeredByUser")
  rotatedTestRailIntegrationSecrets TestRailSuiteIntegration[] @relation("TestRailIntegrationSecretRotatedBy")
  startedTestRailSyncRuns TestRailSyncRun[] @relation("TestRailSyncRunStartedBy")
  auditEvents      AuditEvent[]         @relation("ActorUser")
  sessions         UserSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  submittedFeedback BetaFeedback[]      @relation("SubmittedByUser")
  rotatedGitHubIntegrationSecrets GitHubSuiteIntegration[] @relation("GitHubIntegrationSecretRotatedBy")
  notifications AppNotification[]
  approvedRepoAllowlistEntries GitHubRepositoryAllowlistEntry[] @relation("RepoAllowlistApprovedBy")
  approvedVisualBaselines VisualBaseline[] @relation("BaselineApprover")
  createdApiTests ApiTestDefinition[] @relation("ApiTestCreatedBy")

  @@map("users")
}

model UserSession {
  id                String    @id @default(uuid())
  userId            String
  sessionTokenHash  String    @unique
  activeWorkspaceId String?
  passwordVersion   Int
  ipAddress         String?
  userAgent         String?
  lastActivityAt    DateTime
  expiresAt         DateTime
  revokedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeWorkspace Workspace? @relation(fields: [activeWorkspaceId], references: [id], onDelete: SetNull)

  @@index([userId, expiresAt])
  @@index([activeWorkspaceId])
  @@map("user_sessions")
}

model EmailVerificationToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Membership {
  id          String           @id @default(uuid())
  tenantId    String
  workspaceId String?
  userId      String
  role        MembershipRole
  status      MembershipStatus @default(INVITED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, workspaceId, role])
  @@map("memberships")
}

// ──────────────── Environment ────────────────

model Environment {
  id                 String            @id @default(uuid())
  workspaceId        String
  name               String
  baseUrl            String
  secretRef          String
  encryptedSecretJson String?
  isDefault          Boolean           @default(false)
  status             EnvironmentStatus @default(ACTIVE)
  testTimeoutMs      Int               @default(120000)
  runTimeoutMs       Int               @default(3600000)
  maxRetries         Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  testRuns  TestRun[]
  scheduledSuites AutomationSuite[] @relation("ScheduleEnvironment")
  apiTestExecutions ApiTestExecution[]

  @@map("environments")
}

// ──────────────── Recording & Test Models ────────────────

model RecordingAsset {
  id             String              @id @default(uuid())
  workspaceId    String
  sourceType     RecordingSourceType @default(PLAYWRIGHT_CODEGEN_TS)
  filename       String
  originalPath   String?
  storageKey     String
  checksum       String
  version        Int                 @default(1)
  metadataJson   Json?
  status         RecordingStatus     @default(UPLOADED)
  uploadedByUserId String

  createdAt DateTime @default(now())

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation("UploadedByUser", fields: [uploadedByUserId], references: [id])
  canonicalTests CanonicalTest[]

  @@map("recording_assets")
}

model CanonicalTest {
  id               String     @id @default(uuid())
  workspaceId      String
  suiteId          String?
  recordingAssetId String
  name             String
  description      String?
  tagsJson         Json       @default("[]")
  canonicalVersion Int        @default(1)
  definitionJson   Json
  status           TestStatus @default(INGESTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite          AutomationSuite? @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  recordingAsset RecordingAsset @relation(fields: [recordingAssetId], references: [id])
  generatedArtifacts GeneratedTestArtifact[]
  testRunItems   TestRunItem[]
  aiRepairAttempts AIRepairAttempt[]
  publications GeneratedArtifactPublication[]
  externalCaseLink ExternalTestCaseLink?
  scriptMappings TestCaseScriptMapping[]
  visualBaselines VisualBaseline[]
  fileMappings    TestFileMapping[]

  @@index([suiteId, updatedAt])
  @@index([workspaceId, status, updatedAt])
  @@map("canonical_tests")
}

model GeneratedTestArtifact {
  id               String              @id @default(uuid())
  workspaceId      String
  canonicalTestId  String
  version          Int                 @default(1)
  fileName         String
  storageKey       String
  checksum         String
  generatorVersion String
  status           GeneratedTestStatus @default(CREATED)
  createdByUserId  String?
  metadataJson     Json?
  validationStartedAt DateTime?
  validatedAt      DateTime?

  createdAt DateTime @default(now())

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  canonicalTest CanonicalTest @relation(fields: [canonicalTestId], references: [id])
  createdBy     User?         @relation("CreatedByUser", fields: [createdByUserId], references: [id])
  testRunItems  TestRunItem[]
  aiRepairAttempts AIRepairAttempt[]
  artifacts     Artifact[]
  publication   GeneratedArtifactPublication?

  @@map("generated_test_artifacts")
}

model GeneratedArtifactPublication {
  id                    String                      @id @default(uuid())
  tenantId              String
  workspaceId           String
  suiteId               String
  githubIntegrationId   String
  canonicalTestId       String
  generatedTestArtifactId String                   @unique
  createdByUserId       String?
  idempotencyKey        String                      @unique
  status                PublicationStatus           @default(PENDING)
  targetPath            String
  branchName            String
  defaultBranch         String
  pullRequestNumber     Int?
  pullRequestUrl        String?
  pullRequestState      PublicationPullRequestState?
  headCommitSha         String?
  mergeCommitSha        String?
  lastError             String?
  lastAttemptedAt       DateTime?
  publishedAt           DateTime?
  mergedAt              DateTime?
  lastWebhookEventAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite AutomationSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  githubIntegration GitHubSuiteIntegration @relation(fields: [githubIntegrationId], references: [id], onDelete: Cascade)
  canonicalTest CanonicalTest @relation(fields: [canonicalTestId], references: [id])
  generatedTestArtifact GeneratedTestArtifact @relation(fields: [generatedTestArtifactId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  webhookDeliveries GitHubWebhookDelivery[]
  testRunItems TestRunItem[]

  @@index([workspaceId, status, updatedAt])
  @@index([suiteId, createdAt])
  @@index([githubIntegrationId, branchName])
  @@index([githubIntegrationId, pullRequestNumber])
  @@map("generated_artifact_publications")
}

model GitHubWebhookDelivery {
  id                  String                      @id @default(uuid())
  tenantId            String
  workspaceId         String
  suiteId             String
  githubIntegrationId String
  publicationId       String?
  deliveryId          String
  eventName           String
  action              String?
  status              GitHubWebhookDeliveryStatus @default(RECEIVED)
  payloadJson         Json
  processingAttempts  Int                         @default(0)
  lastError           String?
  receivedAt          DateTime                    @default(now())
  processedAt         DateTime?
  replayedAt          DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite AutomationSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  githubIntegration GitHubSuiteIntegration @relation(fields: [githubIntegrationId], references: [id], onDelete: Cascade)
  publication GeneratedArtifactPublication? @relation(fields: [publicationId], references: [id], onDelete: SetNull)

  @@unique([githubIntegrationId, deliveryId])
  @@index([publicationId, receivedAt])
  @@index([workspaceId, status, receivedAt])
  @@map("github_webhook_deliveries")
}

model GitHubRepositoryAllowlistEntry {
  id          String   @id @default(uuid())
  tenantId    String
  workspaceId String
  repoOwner   String
  repoName    String
  approvedAt  DateTime @default(now())
  approvedByUserId String

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  approvedByUser User @relation("RepoAllowlistApprovedBy", fields: [approvedByUserId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, repoOwner, repoName])
  @@index([tenantId])
  @@map("github_repository_allowlist")
}

model TestRailSuiteIntegration {
  id                    String                    @id @default(uuid())
  tenantId              String
  workspaceId           String
  suiteId               String                    @unique
  baseUrl               String
  projectId             String
  suiteIdExternal       String?
  sectionId             String?
  username              String
  secretRef             String?
  encryptedApiKeyJson   String?
  status                TestRailIntegrationStatus @default(DISCONNECTED)
  syncPolicy            TestRailSyncPolicy        @default(MANUAL)
  healthSummaryJson     Json?
  lastValidatedAt       DateTime?
  lastSyncedAt          DateTime?
  secretRotatedAt       DateTime?
  secretRotatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite AutomationSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  secretRotatedByUser User? @relation("TestRailIntegrationSecretRotatedBy", fields: [secretRotatedByUserId], references: [id], onDelete: SetNull)
  caseLinks ExternalTestCaseLink[]
  syncRuns TestRailSyncRun[]

  @@index([workspaceId, status])
  @@index([tenantId, updatedAt])
  @@map("testrail_suite_integrations")
}

model ExternalTestCaseLink {
  id                  String                 @id @default(uuid())
  workspaceId         String
  suiteId             String
  businessTestCaseId  String?
  canonicalTestId     String?                @unique
  integrationId       String
  externalCaseId      String
  status              TestRailCaseLinkStatus @default(MAPPED)
  ownerEmail          String?
  titleSnapshot       String?
  sectionNameSnapshot String?
  syncSnapshotJson    Json?
  lastSyncedAt        DateTime?
  lastError           String?
  retryEligible       Boolean                @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite AutomationSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  businessTestCase BusinessTestCase? @relation(fields: [businessTestCaseId], references: [id], onDelete: SetNull)
  canonicalTest CanonicalTest? @relation(fields: [canonicalTestId], references: [id], onDelete: Cascade)
  integration TestRailSuiteIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalCaseId])
  @@index([suiteId, status, updatedAt])
  @@map("external_test_case_links")
}

model TestRailSyncRun {
  id              String                 @id @default(uuid())
  tenantId        String
  workspaceId     String
  suiteId         String
  integrationId   String
  startedByUserId String?
  status          TestRailSyncRunStatus  @default(RUNNING)
  scope           String                 @default("suite")
  totalCount      Int                    @default(0)
  syncedCount     Int                    @default(0)
  failedCount     Int                    @default(0)
  summary         String?
  startedAt       DateTime               @default(now())
  finishedAt      DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite AutomationSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  integration TestRailSuiteIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  startedBy User? @relation("TestRailSyncRunStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, startedAt])
  @@index([suiteId, status, startedAt])
  @@map("testrail_sync_runs")
}

// ──────────────── Run Models ────────────────

model TestRun {
  id                 String    @id @default(uuid())
  tenantId           String
  workspaceId        String
  suiteId            String?
  environmentId      String
  triggeredByUserId  String
  runType            RunType   @default(MANUAL)
  requestedSourceMode ExecutionSourceRequestMode @default(SUITE_DEFAULT)
  requestedGitRef     String?
  status             RunStatus @default(QUEUED)
  totalCount         Int       @default(0)
  queuedCount        Int       @default(0)
  runningCount       Int       @default(0)
  passedCount        Int       @default(0)
  failedCount        Int       @default(0)
  canceledCount      Int       @default(0)
  timedOutCount      Int       @default(0)
  startedAt          DateTime?
  finishedAt         DateTime?

  createdAt DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite       AutomationSuite? @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  environment Environment @relation(fields: [environmentId], references: [id])
  triggeredBy User        @relation("TriggeredByUser", fields: [triggeredByUserId], references: [id])
  items       TestRunItem[]
  testCaseResults TestCaseResult[]
  artifacts   Artifact[]
  aiRepairAttempts AIRepairAttempt[]
  smartSelection SmartSelectionRun?
  apiTestExecutions ApiTestExecution[]

  @@index([workspaceId, createdAt, status])
  @@index([suiteId, createdAt])
  @@map("test_runs")
}

model TestRunItem {
  id                       String    @id @default(uuid())
  testRunId                String
  canonicalTestId          String
  generatedTestArtifactId  String
  publicationId            String?
  testCaseResultId         String?
  sequence                 Int
  requestedSourceMode      ExecutionSourceRequestMode @default(SUITE_DEFAULT)
  requestedGitRef          String?
  resolvedSourceMode       ExecutionSourceMode        @default(STORAGE_ARTIFACT)
  resolvedGitRef           String?
  resolvedCommitSha        String?
  sourceFallbackReason     String?
  status                   RunStatus @default(QUEUED)
  startedAt                DateTime?
  finishedAt               DateTime?
  failureSummary           String?
  workerJobId              String?
  retryCount               Int       @default(0)

  testRun                TestRun               @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  canonicalTest          CanonicalTest         @relation(fields: [canonicalTestId], references: [id])
  generatedTestArtifact  GeneratedTestArtifact @relation(fields: [generatedTestArtifactId], references: [id])
  publication            GeneratedArtifactPublication? @relation(fields: [publicationId], references: [id], onDelete: SetNull)
  testCaseResult         TestCaseResult?       @relation(fields: [testCaseResultId], references: [id], onDelete: SetNull)
  artifacts              Artifact[]
  aiRepairAttempts       AIRepairAttempt[]
  browserResults         TestRunBrowserResult[]

  @@index([testRunId, status])
  @@index([testRunId, resolvedSourceMode])
  @@map("test_run_items")
}

// ──────────────── Artifacts ────────────────

model Artifact {
  id             String       @id @default(uuid())
  workspaceId    String
  testRunId      String?
  testRunItemId  String?
  generatedTestArtifactId String?
  artifactType   ArtifactType
  fileName       String
  storageKey     String
  contentType    String
  sizeBytes      BigInt
  checksum       String

  createdAt DateTime @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  testRun     TestRun?     @relation(fields: [testRunId], references: [id])
  testRunItem TestRunItem? @relation(fields: [testRunItemId], references: [id])
  generatedTestArtifact GeneratedTestArtifact? @relation(fields: [generatedTestArtifactId], references: [id])

  @@index([workspaceId, testRunId, artifactType])
  @@index([workspaceId, generatedTestArtifactId, artifactType])
  @@map("artifacts")
}

// ──────────────── Visual Baselines ────────────────

model VisualBaseline {
  id               String   @id @default(uuid())
  workspaceId      String
  canonicalTestId  String
  stepIndex        Int
  stepLabel        String?
  storageKey       String
  contentType      String   @default("image/png")
  width            Int      @default(0)
  height           Int      @default(0)
  perceptualHash   String?
  sizeBytes        BigInt   @default(0)
  approvedByUserId String?
  approvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  canonicalTest CanonicalTest @relation(fields: [canonicalTestId], references: [id], onDelete: Cascade)
  approvedBy    User?         @relation("BaselineApprover", fields: [approvedByUserId], references: [id])

  @@unique([canonicalTestId, stepIndex])
  @@index([workspaceId, canonicalTestId])
  @@map("visual_baselines")
}

enum VisualDiffStatus {
  NO_BASELINE
  MATCH
  MISMATCH
  APPROVED
}

// ──────────────── Smart Test Selection (P3.1) ────────────────

model TestFileMapping {
  id              String   @id @default(uuid())
  workspaceId     String
  canonicalTestId String
  filePattern     String
  routePattern    String?
  confidence      Float    @default(1.0)
  learnedFrom     String   @default("manual")  // manual | execution_trace | git_history

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  canonicalTest CanonicalTest @relation(fields: [canonicalTestId], references: [id], onDelete: Cascade)

  @@unique([canonicalTestId, filePattern])
  @@index([workspaceId])
  @@map("test_file_mappings")
}

model SmartSelectionRun {
  id                 String   @id @default(uuid())
  workspaceId        String
  testRunId          String   @unique
  repoOwner          String
  repoName           String
  baseSha            String
  headSha            String
  pullRequestNumber  Int?
  changedFilesJson   Json
  totalTests         Int      @default(0)
  selectedTests      Int      @default(0)
  randomSampleTests  Int      @default(0)
  coverageConfidence Float    @default(0)

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  testRun   TestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("smart_selection_runs")
}

// ──────────────── Multi-Browser Matrix (P3.2) ────────────────

enum BrowserType {
  CHROMIUM
  FIREFOX
  WEBKIT
}

enum DeviceProfile {
  DESKTOP
  TABLET
  MOBILE
}

model TestRunBrowserResult {
  id            String        @id @default(uuid())
  testRunItemId String
  browserType   BrowserType
  device        DeviceProfile @default(DESKTOP)
  viewportWidth Int           @default(1920)
  viewportHeight Int          @default(1080)
  status        RunStatus     @default(QUEUED)
  failureSummary String?
  durationMs    Int?
  startedAt     DateTime?
  finishedAt    DateTime?

  createdAt DateTime @default(now())

  testRunItem TestRunItem @relation(fields: [testRunItemId], references: [id], onDelete: Cascade)

  @@unique([testRunItemId, browserType, device])
  @@index([testRunItemId, status])
  @@map("test_run_browser_results")
}

// ──────────────── API Testing Extension (P3.3) ────────────────

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
  HEAD
  OPTIONS
}

enum ApiTestProtocol {
  REST
  GRAPHQL
}

enum ApiTestStatus {
  DRAFT
  READY
  ARCHIVED
}

model ApiTestDefinition {
  id            String          @id @default(uuid())
  workspaceId   String
  suiteId       String?
  name          String
  description   String?
  protocol      ApiTestProtocol @default(REST)
  method        HttpMethod      @default(GET)
  urlTemplate   String
  headersJson   Json            @default("{}")
  bodyTemplate  String?
  graphqlQuery  String?
  graphqlVariablesJson Json?
  assertionsJson Json           @default("[]")
  status         ApiTestStatus  @default(DRAFT)
  tagsJson       Json           @default("[]")
  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite     AutomationSuite? @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  createdBy User?            @relation("ApiTestCreatedBy", fields: [createdByUserId], references: [id])
  executions ApiTestExecution[]

  @@index([workspaceId, status])
  @@index([suiteId])
  @@map("api_test_definitions")
}

model ApiTestExecution {
  id                String    @id @default(uuid())
  workspaceId       String
  apiTestDefinitionId String
  testRunId         String?
  environmentId     String
  status            RunStatus @default(QUEUED)
  requestUrl        String?
  requestMethod     String?
  requestHeadersJson Json?
  requestBody       String?
  responseStatus    Int?
  responseHeadersJson Json?
  responseBody      String?
  responseTimeMs    Int?
  assertionResultsJson Json?
  failureSummary    String?
  startedAt         DateTime?
  finishedAt        DateTime?

  createdAt DateTime @default(now())

  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  apiTestDefinition ApiTestDefinition @relation(fields: [apiTestDefinitionId], references: [id], onDelete: Cascade)
  testRun         TestRun?          @relation(fields: [testRunId], references: [id], onDelete: SetNull)
  environment     Environment       @relation(fields: [environmentId], references: [id])

  @@index([apiTestDefinitionId, createdAt])
  @@index([testRunId])
  @@map("api_test_executions")
}

// ──────────────── Audit ────────────────

model AuditEvent {
  id           String   @id @default(uuid())
  tenantId     String
  workspaceId  String?
  actorUserId  String?
  eventType    String
  entityType   String
  entityId     String
  requestId    String?
  metadataJson Json?

  createdAt DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  actor     User?      @relation("ActorUser", fields: [actorUserId], references: [id])

  @@index([tenantId, workspaceId, createdAt, eventType])
  @@map("audit_events")
}

// ──────────────── AI Repair ────────────────

model AIRepairAttempt {
  id                       String        @id @default(uuid())
  workspaceId              String
  canonicalTestId          String
  generatedTestArtifactId  String
  testRunId                String?
  testRunItemId            String?
  attemptNumber            Int
  repairMode               RepairMode
  inputFailureHash         String
  promptVersion            String
  modelName                String?
  status                   RepairStatus  @default(SUGGESTED)
  diffSummary              String?
  patchStorageKey          String?
  sanitizationMetadataJson Json?
  startedAt                DateTime
  finishedAt               DateTime?

  createdAt DateTime @default(now())

  workspace             Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  canonicalTest         CanonicalTest         @relation(fields: [canonicalTestId], references: [id])
  generatedTestArtifact GeneratedTestArtifact @relation(fields: [generatedTestArtifactId], references: [id])
  testRun               TestRun?              @relation(fields: [testRunId], references: [id])
  testRunItem           TestRunItem?          @relation(fields: [testRunItemId], references: [id])

  @@unique([generatedTestArtifactId, attemptNumber])
  @@map("ai_repair_attempts")
}

// ──────────────── Usage Metering ────────────────

model UsageMeter {
  id                String     @id @default(uuid())
  tenantId          String
  workspaceId       String?
  metricType        MetricType
  metricWindowStart DateTime
  metricWindowEnd   DateTime
  value             Float
  unit              String

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("usage_meters")
}

model BetaFeedback {
  id               String            @id @default(uuid())
  tenantId         String
  workspaceId      String
  submittedByUserId String
  title            String
  summary          String
  category         FeedbackCategory  @default(OTHER)
  priority         FeedbackPriority  @default(MEDIUM)
  status           FeedbackStatus    @default(SUBMITTED)
  metadataJson     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submittedBy User      @relation("SubmittedByUser", fields: [submittedByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, priority, createdAt])
  @@map("beta_feedback")
}

// ──────────────── Business Test Cases ────────────────

model BusinessTestCase {
  id               String                    @id @default(uuid())
  workspaceId      String
  suiteId          String
  title            String
  description      String?
  format           BusinessTestCaseFormat     @default(SIMPLE)
  source           BusinessTestCaseSource    @default(MANUAL)
  status           BusinessTestCaseStatus    @default(ACTIVE)
  priority         BusinessTestCasePriority  @default(MEDIUM)
  preconditions    String?
  stepsJson        Json?
  expectedResult   String?
  tagsJson         Json                      @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  suite         AutomationSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  scriptMappings TestCaseScriptMapping[]
  testCaseResults TestCaseResult[]
  externalCaseLinks ExternalTestCaseLink[]

  @@index([suiteId, status, updatedAt])
  @@index([workspaceId, status])
  @@map("business_test_cases")
}

model TestCaseScriptMapping {
  id                String @id @default(uuid())
  businessTestCaseId String
  canonicalTestId    String

  createdAt DateTime @default(now())

  businessTestCase BusinessTestCase @relation(fields: [businessTestCaseId], references: [id], onDelete: Cascade)
  canonicalTest    CanonicalTest    @relation(fields: [canonicalTestId], references: [id], onDelete: Cascade)

  @@unique([businessTestCaseId, canonicalTestId])
  @@index([canonicalTestId])
  @@map("test_case_script_mappings")
}

model TestCaseResult {
  id                 String          @id @default(uuid())
  testRunId          String
  businessTestCaseId String
  verdict            TestCaseVerdict @default(NOT_COVERED)
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  testRun          TestRun          @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  businessTestCase BusinessTestCase @relation(fields: [businessTestCaseId], references: [id])
  runItems         TestRunItem[]

  @@unique([testRunId, businessTestCaseId])
  @@index([testRunId, verdict])
  @@map("test_case_results")
}

// ──────────────── Retention ────────────────

model RetentionSetting {
  id              String @id @default(uuid())
  workspaceId     String @unique
  logsDays        Int    @default(30)
  screenshotsDays Int    @default(14)
  videosDays      Int    @default(7)
  tracesDays      Int    @default(14)
  auditDays       Int    @default(90)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("retention_settings")
}

// ──────────────── In-App Notifications ────────────────

model AppNotification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  message     String?
  entityType  String?
  entityId    String?
  read        Boolean  @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("app_notifications")
}

// ──────────────── LLM Configuration ────────────────

model PlatformLlmConfig {
  id                  String          @id @default(uuid())
  displayName         String
  provider            LlmProviderType
  modelName           String
  baseUrl             String?
  encryptedApiKey     String?
  repairModelName     String?
  isActive            Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantSelections TenantLlmSelection[]

  @@map("platform_llm_configs")
}

model TenantLlmSelection {
  id                    String @id @default(uuid())
  tenantId              String @unique

  // Platform config selection (null when using BYO custom config)
  platformLlmConfigId   String?

  // BYO custom config fields (used when platformLlmConfigId is null)
  customProvider        LlmProviderType?
  customModelName       String?
  customBaseUrl         String?
  customEncryptedApiKey String?
  customRepairModelName String?
  customDisplayName     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformLlmConfig   PlatformLlmConfig? @relation(fields: [platformLlmConfigId], references: [id], onDelete: Cascade)

  @@map("tenant_llm_selections")
}
