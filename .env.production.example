# ============================================================
#  Selora — Production Environment Template
# ============================================================
#  Copy this file to .env (or inject via your deployment tool)
#  and fill in every <CHANGE_ME> placeholder before deploying.
#
#  🔴  = MUST change — contains secrets or host-specific values
#  🟡  = Review — sensible default, but tune for your setup
#  🟢  = Likely fine as-is
# ============================================================

# ─── Infrastructure ─────────────────────────────

# 🔴 Postgres
POSTGRES_USER=selora
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_DB_PASSWORD>
POSTGRES_DB=selora
DATABASE_URL=postgresql://selora:<CHANGE_ME_STRONG_DB_PASSWORD>@<DB_HOST>:5432/selora?schema=public&connection_limit=20&pool_timeout=30

# 🔴 Redis
REDIS_URL=redis://:<CHANGE_ME_REDIS_PASSWORD>@<REDIS_HOST>:6379

# 🔴 S3 / Object Storage
S3_ACCESS_KEY=<CHANGE_ME_S3_ACCESS_KEY>
S3_SECRET_KEY=<CHANGE_ME_S3_SECRET_KEY>
S3_ENDPOINT=https://<S3_ENDPOINT>
S3_BUCKET=selora-artifacts
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=false

# 🟢 Storage driver (s3 for production)
STORAGE_DRIVER=s3

# ─── Application ───────────────────────────────

# 🟢 Must be "production"
NODE_ENV=production

# 🟡 API port (keep 4000 behind reverse proxy)
API_PORT=4000

# 🔴 Secrets — generate with: openssl rand -base64 48
API_SESSION_SECRET=<CHANGE_ME_64_CHAR_RANDOM_STRING>
SECRET_ENCRYPTION_KEY=<CHANGE_ME_64_CHAR_RANDOM_STRING>
ARTIFACT_SIGNING_SECRET=<CHANGE_ME_64_CHAR_RANDOM_STRING>

# 🟡 Signed artifact download link expiry (seconds)
ARTIFACT_DOWNLOAD_TTL_SECONDS=900

# 🔴 CORS & public-facing URLs (your actual domain)
WEB_ORIGIN=https://<YOUR_DOMAIN>
API_PUBLIC_ORIGIN=https://api.<YOUR_DOMAIN>

# 🟢 Queue mode (always bullmq in production)
QUEUE_MODE=bullmq

# 🟡 Rate limits (requests per minute)
API_RATE_LIMIT_USER_PER_MINUTE=30
API_RATE_LIMIT_TENANT_PER_MINUTE=300

# ─── AI / LLM ──────────────────────────────────

# 🔴 AI provider configuration
AI_PROVIDER_BASE_URL=<CHANGE_ME_LLM_ENDPOINT>
AI_PROVIDER_API_URL=<CHANGE_ME_LLM_ENDPOINT>
AI_PROVIDER_API_KEY=<CHANGE_ME_LLM_API_KEY>
AI_MODEL=<YOUR_MODEL>
AI_REPAIR_MODEL=<YOUR_MODEL>

# 🟡 LLM request timeout (ms)
AI_LLM_TIMEOUT_MS=120000

# ─── Execution & Validation ────────────────────

# 🟡 Timeouts (ms)
EXECUTION_TIMEOUT_MS=120000
VALIDATION_TIMEOUT_MS=60000

# 🟡 Docker-based Playwright execution
PLAYWRIGHT_RUNNER_IMAGE=selora-playwright-runner
DOCKER_NETWORK=selora_default
VALIDATION_HOST_ROOT=/tmp/selora-validation

# ─── Web ────────────────────────────────────────

# 🔴 Must match your production API URL
NEXT_PUBLIC_API_URL=https://api.<YOUR_DOMAIN>
WEB_PORT=3000

# ─── Email (SMTP) ──────────────────────────────

# 🔴 Production SMTP server
SMTP_HOST=<CHANGE_ME_SMTP_HOST>
SMTP_PORT=587
SMTP_FROM=noreply@<YOUR_DOMAIN>
SMTP_USER=<CHANGE_ME_SMTP_USER>
SMTP_PASSWORD=<CHANGE_ME_SMTP_PASSWORD>
